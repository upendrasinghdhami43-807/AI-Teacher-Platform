# APPLICATION
APP_ENV=development
DEBUG=true
SECRET_KEY=dev-secret-key-change-in-production-please

# DATABASE
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/ai_teacher_db

# REDIS
REDIS_URL=redis://localhost:6379/0

# AI PROVIDERS
AI_PRIMARY_PROVIDER=gemini
AI_FALLBACK_PROVIDER=groq
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_DIRECTOR_MODEL=gemini-2.5-flash-lite
GEMINI_SCRIPT_MODEL=gemini-2.5-flash
GEMINI_BOARD_MODEL=gemini-2.5-flash-lite
GEMINI_MEMORY_MODEL=gemini-2.5-flash-lite
GEMINI_QUESTION_MODEL=gemini-2.5-flash

# GROQ (cheap fallback — optional)
GROQ_API_KEY=your_groq_api_key_here
GROQ_BOARD_MODEL=llama-3.1-8b-instant
GROQ_MEMORY_MODEL=llama-3.1-8b-instant

# OPENAI (fallback — optional)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_SCRIPT_MODEL=gpt-4o

# AZURE SPEECH TTS
AZURE_SPEECH_KEY=your_azure_speech_key_here
AZURE_SPEECH_REGION=eastasia
AZURE_VOICE_ENGLISH=en-US-AriaNeural
AZURE_VOICE_NEPALI=ne-NP-HemkalaNeural
AZURE_VOICE_HINDI=hi-IN-SwaraNeural
AZURE_VOICE_NEENGLISH_NE=ne-NP-HemkalaNeural
AZURE_VOICE_NEENGLISH_EN=en-US-JennyNeural

# COST CONTROL
FREE_PLAN_DAILY_AI_LESSONS=5
BASIC_PLAN_DAILY_AI_LESSONS=-1
MAX_LESSON_TOKENS_INPUT=4000
MAX_LESSON_TOKENS_OUTPUT=3000
ENABLE_SEMANTIC_CACHE=true
LESSON_CACHE_TTL_HOURS=168

# STORAGE
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./storage

# WEBSOCKET
WS_HEARTBEAT_INTERVAL=30
WS_MAX_SESSION_DURATION=3600
